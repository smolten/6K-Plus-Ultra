<script src="_rk_data.js"></script>
<div id="rk-container"></div>
<script>
function toggleRK(id){
  var w=document.getElementById(id+'-words');
  var t=document.getElementById(id+'-toggle');
  if(!w||!t)return;
  if(w.style.display==='none'){
    w.style.display='inline';
    t.querySelector('.rk-arrow').textContent='\u25C0';
    t.querySelector('.rk-count').style.display='none';
  }else{
    w.style.display='none';
    t.querySelector('.rk-arrow').textContent='\u25B6';
    t.querySelector('.rk-count').style.display='';
  }
}
function renderRK(src){
  var vocab='{{Vocabulary-Kanji}}';
  var kanji=[];
  var seen={};
  for(var i=0;i<vocab.length;i++){
    var cp=vocab.charCodeAt(i);
    if((cp>=0x4E00&&cp<=0x9FFF)||(cp>=0x3400&&cp<=0x4DBF)){
      if(!seen[vocab[i]]){seen[vocab[i]]=1;kanji.push(vocab[i]);}
    }
  }
  var c=document.getElementById('rk-container');
  if(!kanji.length||typeof RK==='undefined'){
    c.textContent='No Related Kanji/Vocab';
    return;
  }
  var html='';
  var hasAny=false;
  for(var i=0;i<kanji.length;i++){
    var k=kanji[i];
    var d=RK[k];
    if(!d)continue;
    hasAny=true;
    var id='rk-'+i;
    html+='<div class="rk-row" id="'+id+'">';
    html+=d.l;
    html+='<span class="rk-toggle" id="'+id+'-toggle" onclick="toggleRK(\''+id+'\');event.stopPropagation();event.preventDefault();">';
    html+='<span class="rk-arrow">\u25B6</span><span class="rk-count">(+'+d.n+')</span>';
    html+='</span>';
    html+='<span class="rk-words" id="'+id+'-words" style="display:none">'+d.w+'</span>';
    html+='</div>';
  }
  if(vocab.indexOf('\u3005')>=0){
    html+='<div class="rk-row"><b><ruby>\u3005<rt>\u304A\u3069\u308A\u3058</rt></ruby></b>&emsp;\u8E0A\u308A\u5B57 \u2014 repeat the previous kanji</div>';
  }
  if(!hasAny){
    c.textContent='No Related Kanji/Vocab';
    return;
  }
  c.className='rk-field';
  c.innerHTML=html;
  var ws=c.querySelectorAll('.rk-w');
  for(var j=0;j<ws.length;j++){
    if(ws[j].getAttribute('data-w')===vocab) ws[j].classList.add('rk-self');
  }
  var allRows=c.querySelectorAll('.rk-row');
  for(var r=0;r<allRows.length;r++){
    var yomi=allRows[r].querySelector('.rk-yomi');
    if(yomi){
      yomi.style.maxWidth='';
      var kun=yomi.querySelector('.rk-kun');
      var on=yomi.querySelector('.rk-on');
      if(kun)kun.style.display='inline-block';
      if(on)on.style.display='inline-block';
      var kunW=kun?kun.offsetWidth:0;
      var onW=on?on.offsetWidth:0;
      if(kun)kun.style.display='';
      if(on)on.style.display='';
      if(kunW>onW&&kunW>0){
        yomi.style.maxWidth=Math.ceil(kunW/2)+'px'; // kunW/2 splits kun+nanori into max 2 lines
        void yomi.offsetWidth; // force reflow
        if(yomi.scrollWidth>yomi.offsetWidth){yomi.style.maxWidth=yomi.scrollWidth+'px';} // widen to fit content
      }
    }
  }
  c.addEventListener('click',function(e){
    var m=e.target.closest('.jlpt-marker');
    if(!m)return;
    var row=m.closest('.rk-row');
    if(!row)return;
    var rid=row.id;
    if(rid)toggleRK(rid);
    e.stopPropagation();e.preventDefault();
  });
}
if(typeof RK!=='undefined'){renderRK('ok');}
else{var s=document.createElement('script');s.src='_rk_data.js';s.onload=function(){if(typeof RK!=='undefined')renderRK('ok');else document.getElementById('rk-container').textContent='RK not loaded';};s.onerror=function(){document.getElementById('rk-container').textContent='RK not loaded';};document.head.appendChild(s);}
// Desktop: intercept shirabe links and open tangorin instead
if(document.querySelector('.win,.desktop')||(/Windows/.test(navigator.userAgent)&&!/iPhone|iPad|iPod/.test(navigator.userAgent))){
  document.addEventListener('click',function(e){
    var a=e.target.closest('a[href^="shirabelookup://"]');
    if(a){
      e.preventDefault();e.stopPropagation();
      var w=decodeURIComponent(a.href.replace('shirabelookup://search?w=',''));
      window.open('https://tangorin.com/kanji?search='+encodeURIComponent(w)+'%20%23kanji');
    }
  });
}
</script>
