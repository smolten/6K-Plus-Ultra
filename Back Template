<script>
function toggleDef(){
  var c=document.getElementById('def-content');
  var b=document.getElementById('def-br');
  var btn=document.getElementById('def-btn');
  if(!c)return;
  if(c.style.display==='none'){
    c.style.display='';if(b)b.style.display='';btn.textContent='\u{1f4d6}';
  }else{
    c.style.display='none';if(b)b.style.display='none';btn.textContent='\u{1f4d5}';
  }
}
var _defTouchY=0;
document.addEventListener('touchstart',function(e){_defTouchY=e.touches[0].clientY;},{passive:true});
function closeDef(e){
  var sel=window.getSelection();if(sel.toString()){sel.removeAllRanges();e.stopPropagation();e.preventDefault();return;}
  if(e.type==='touchend'&&e.changedTouches&&Math.abs(e.changedTouches[0].clientY-_defTouchY)>5){e.stopPropagation();e.preventDefault();return;}
  var c=document.getElementById('def-content');
  var b=document.getElementById('def-br');
  var btn=document.getElementById('def-btn');
  if(c){c.style.display='none';if(b)b.style.display='none';btn.textContent='\u{1f4d5}';}
  e.stopPropagation();e.preventDefault();
}
function toggleStroke(){
  var c=document.getElementById('stroke-content');
  var btn=document.getElementById('stroke-btn');
  if(!c)return;
  if(c.style.display==='none'){
    c.style.display='';btn.textContent='\u2b1c';
  }else{
    c.style.display='none';btn.textContent='\u{1f235}';
  }
}
function zoomImg(e){
  if(e.target.tagName==='IMG'){e.target.classList.toggle('zoomed');}
}

// Desktop: intercept shirabe links and open tangorin instead
if(document.body.classList.contains('win')){
  document.addEventListener('click',function(e){
    var a=e.target.closest('a[href^="shirabelookup://"]');
    if(a){
      e.preventDefault();e.stopPropagation();
      var w=decodeURIComponent(a.href.replace('shirabelookup://search?w=',''));
      window.open('https://tangorin.com/kanji?search='+encodeURIComponent(w)+'%20%23kanji');
    }
  });
}
</script>
